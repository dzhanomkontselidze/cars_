<!--view table of students-->
    <a href="/">
    <button style="color:#18db69; background-color:#778899;  border-radius: 24px; font-family: Garamond; font-weight: 600; font-size: 24px; width: 10vw ">Назад</button>
    </a>
    
    
<table>
    <thead>
    <tr>
        <th scope="col">ID</th>
        <th scope="col">Назва вправи</th>
        <th scope="col">Рівень складності</th>
        <th scope="col">Рівень підготовки</th>
        <th scope="col">Група мязів</th>
        <th scope="col">Кількість підходів</th>
    </tr>
    </thead>
    <tbody>
    {{#each exercise}}
        <tr>
            <th scope="row">{{this.id}}</th>
            <td>{{this.exercise_name}}</td>
            <td>{{this.difficult_level}}</td>
            <td>{{this.required_level}}</td>
            <td>{{this.Muscle_name}}</td>
            <td>{{this.Sets}}</td>
        </tr>
    {{/each}}
    </tbody>
</table>
